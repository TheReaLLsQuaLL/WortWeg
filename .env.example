# Server-only secrets. Do not expose these with EXPO_PUBLIC_.
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
# Comma-separated production web origins. Leave empty for local development.
ALLOWED_ORIGINS=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_CHEAP_MODEL=gemini-3.1-flash-lite
OPENAI_API_KEY=
STT_PROVIDER=openai
STT_MODEL=gpt-4o-mini-transcribe
AI_PROVIDER_TIMEOUT_MS=30000
SPEECH_PROVIDER_TIMEOUT_MS=45000
SPEECH_SCORING_PROVIDER=transcript
SPEECH_AZURE_ENABLED=false
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_AI_MAX=30
RATE_LIMIT_SPEECH_MAX=10
RATE_LIMIT_HEALTH_MAX=120

# Server/internal backend URL. localhost is correct for curl, backend jobs,
# simulators, and tools running on this Mac.
AI_BACKEND_URL=http://localhost:3001

# Expo Go on a real phone cannot use localhost for your Mac.
# Replace YOUR_MAC_LAN_IP with the LAN IP shown by Expo or by:
# ipconfig getifaddr en0
EXPO_PUBLIC_AI_BACKEND_URL=http://YOUR_MAC_LAN_IP:3001

# Mobile AI fetch timeout in milliseconds. Default is 30000.
EXPO_PUBLIC_AI_TIMEOUT_MS=30000

# Mobile speech upload timeout in milliseconds. Default is 45000.
EXPO_PUBLIC_SPEECH_TIMEOUT_MS=45000

# Optional feedback URL for the Profile screen "Geri bildirim gönder" button.
# Set to a Notion form, WhatsApp link, or any URL your testers can open.
# If empty, the button falls back to a blank mailto: draft, or a calm message
# if no mail client is available. Do not put API keys or secrets here.
EXPO_PUBLIC_FEEDBACK_URL=

SUPABASE_URL=
SUPABASE_ANON_KEY=
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
