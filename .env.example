# Server-only secrets. Do not expose these with EXPO_PUBLIC_.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_CHEAP_MODEL=gemini-3.1-flash-lite
OPENAI_API_KEY=
STT_PROVIDER=openai
STT_MODEL=gpt-4o-mini-transcribe

# Server/internal backend URL. localhost is correct for curl, backend jobs,
# simulators, and tools running on this Mac.
AI_BACKEND_URL=http://localhost:3001

# Expo Go on a real phone cannot use localhost for your Mac.
# Replace YOUR_MAC_LAN_IP with the LAN IP shown by Expo or by:
# ipconfig getifaddr en0
EXPO_PUBLIC_AI_BACKEND_URL=http://YOUR_MAC_LAN_IP:3001

# Mobile AI fetch timeout in milliseconds. Default is 30000.
EXPO_PUBLIC_AI_TIMEOUT_MS=30000

# Mobile speech upload timeout in milliseconds. Default is 45000.
EXPO_PUBLIC_SPEECH_TIMEOUT_MS=45000

SUPABASE_URL=
SUPABASE_ANON_KEY=
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
